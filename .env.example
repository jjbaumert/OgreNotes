# AWS Configuration
AWS_PROFILE=ogrenotes-dev
AWS_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=dev-yourname-
S3_BUCKET=dev-yourname-ogrenotes-data

# Redis
REDIS_URL=redis://localhost:6379

# OAuth (GitHub)
OAUTH_CLIENT_ID=your-github-oauth-client-id
OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=replace-with-a-random-string-at-least-32-bytes-long

# Server
API_PORT=3000
FRONTEND_ORIGIN=http://localhost:8080
