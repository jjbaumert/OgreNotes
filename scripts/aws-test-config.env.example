# AWS Budget Test Deployment Configuration
# Copy this file to aws-test-config.env and fill in your values.
#
# Usage (CDK — supersedes the old aws-test-deploy.sh):
#   cp scripts/aws-test-config.env.example scripts/aws-test-config.env
#   # edit the file
#   set -a && source scripts/aws-test-config.env && set +a   # export to CDK
#   cd infra && npm run deploy -- -c env=test -c prefix=<your-stack-prefix>
#
# `set -a` matters: these are plain VAR= assignments, so a bare `source`
# leaves them unexported and the CDK synth (config.ts reads process.env)
# never sees them — silently degrading OAuth/HTTPS. Pass `-c prefix=` to
# match an existing stack (omitting it defaults to `test-`).

# ─── Required ───────────────────────────────────────────────────

# AWS region to deploy into
AWS_REGION=us-east-1

# Prefix for all resource names (use your name or team to avoid collisions)
# Must be lowercase, letters/numbers/hyphens only, end with hyphen
STACK_PREFIX=test-alice-

# GitHub OAuth app credentials (create at https://github.com/settings/developers)
OAUTH_CLIENT_ID=your-github-client-id
OAUTH_CLIENT_SECRET=your-github-client-secret

# Google OAuth credentials (optional — create at https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: https://your-domain/api/v1/auth/callback/google
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_URI=http://FILL_IN_ALB_DNS/api/v1/auth/callback

# JWT signing secret (at least 32 characters)
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes

# Email for AWS Budget alert notifications
NOTIFICATION_EMAIL=you@example.com

# ─── Optional ───────────────────────────────────────────────────

# Frontend origin for CORS (set to ALB DNS after first deploy)
# FRONTEND_ORIGIN=http://FILL_IN_ALB_DNS

# Enable dev-login endpoint (bypasses OAuth for testing)
# DEV_MODE=true

# ─── Phase 6 RAG / AI (Phase 6.2 — Phase 6.3) ───────────────────
#
# Two cloud APIs power the RAG track: Amazon Bedrock for embeddings
# (Phase 6.2) and Anthropic Claude for the agent loop (Phase 6.3).
# Both must be enabled at the AWS account / vendor level before the
# deploy script can put the API to work; the script provisions the
# IAM permissions but does NOT toggle vendor-side model access.
#
# ─── Bedrock model access ───
#
# AWS Bedrock requires per-region per-model access grants via the
# AWS Console (no CLI toggle as of 2026). Do this BEFORE
# aws-test-deploy.sh first runs in a new region:
#
#   1. Open the Bedrock console in your deploy region.
#   2. Sidebar → Model access → Modify model access.
#   3. Tick `amazon.titan-embed-text-v2:0` (the default embedding
#      model). Also tick `cohere.embed-english-v3` if you plan to
#      benchmark alternatives.
#   4. Submit. Approval is instant for first-party Amazon models;
#      Cohere may take a minute.
#
# The aws-test-deploy.sh task-role policy grants
# bedrock:InvokeModel for the canonical four embedding models
# (amazon.titan-embed-text-v2:0, amazon.titan-embed-text-v1,
# cohere.embed-english-v3, cohere.embed-multilingual-v3). Adding
# a fifth requires both a console toggle AND an IAM policy
# update.
#
# Optional model overrides (defaults match the embeddings crate):
# EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# EMBEDDING_DIMENSIONS=1024
#
# ─── Anthropic API key ───
#
# Required for the /api/v1/ask agentic endpoint. Stored in SSM
# Parameter Store as a SecureString — never set here as a plain
# env var. Per stack, run once:
#
#   aws ssm put-parameter \
#       --name "/${STACK_PREFIX}ogrenote/anthropic-api-key" \
#       --type SecureString \
#       --value "sk-ant-..." \
#       --region "${AWS_REGION}"
#
# aws-test-deploy.sh detects the parameter and wires its ARN into
# the ECS task definition's `secrets` field; the value never
# touches the deploy log or the task-def JSON. If the parameter
# isn't set, the /ask endpoint returns 503 (the rest of the stack
# is unaffected).
#
# Rotation:
#   aws ssm put-parameter --overwrite \
#       --name "/${STACK_PREFIX}ogrenote/anthropic-api-key" \
#       --type SecureString --value "sk-ant-..." \
#       --region "${AWS_REGION}"
#   aws ecs update-service --cluster "${STACK_PREFIX}ogrenote" \
#       --service "${STACK_PREFIX}ogrenote-api" \
#       --force-new-deployment --region "${AWS_REGION}"
#
# Optional override (defaults to claude-sonnet-4-6):
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Auto-computed (do not set) ───
#
# QDRANT_URL — populated by aws-test-deploy.sh from the Cloud Map
# private namespace it creates. Setting it here would override
# the live value and likely point at a stale endpoint.

# ─── Other ───

# Admin emails — these users automatically get admin on login (comma-separated)
# ADMIN_EMAILS=joel@example.com,alice@example.com

# Deployment environment label — sets the `Environment` dimension on all
# CloudWatch metrics emitted via EMF, so dev / staging / prod don't collide.
# Defaults to "test" (aws-test-deploy.sh) or "prod" (aws-redeploy.sh).
# DEPLOY_ENV=staging

# Custom domain with HTTPS (optional — requires Route 53 hosted zone)
# The hosted zone must already exist in Route 53 for this domain.
# DOMAIN_NAME=example.com
