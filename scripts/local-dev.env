# Local development environment for the OgreNotes API server.
# Usage (from repo root):
#   docker compose up -d
#   set -a && source scripts/local-dev.env && set +a
#   cargo run --bin setup_dev      # first time / after `docker compose down`
#   cargo run                      # start the API on :3000
#
# NOTE: local only — do NOT commit real secrets; do NOT source this in a
# shell that also sourced scripts/aws-test-config.env (that file points
# REDIS_URL / creds at AWS and will shadow these).

# ── required (server panics if unset) ──
export JWT_SECRET=local-dev-secret-please-change-me-32bytes
export DYNAMODB_TABLE_PREFIX=dev-
export S3_BUCKET=dev-ogrenotes
export OAUTH_CLIENT_ID=dummy          # unused under DEV_MODE (dev-login), but must be set
export OAUTH_CLIENT_SECRET=dummy
export OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# ── dev switches ──
export DEV_MODE=true                  # allows http:// FRONTEND_ORIGIN + enables /auth/dev-login

# ── local Compose services ──
export REDIS_URL=redis://localhost:6379

# AWS creds MUST be minioadmin/minioadmin: DynamoDB Local ignores creds,
# but MinIO validates them and rejects anything else (InvalidAccessKeyId).
export AWS_REGION=us-east-1
export AWS_ACCESS_KEY_ID=minioadmin
export AWS_SECRET_ACCESS_KEY=minioadmin

# Endpoint overrides point the AWS SDK at the local containers.
export AWS_ENDPOINT_URL_DYNAMODB=http://localhost:8000
export AWS_ENDPOINT_URL_S3=http://localhost:9000

# ── optional ──
# export QDRANT_URL=http://localhost:6334   # enables vector/semantic search
# export ADMIN_EMAILS=you@example.com
